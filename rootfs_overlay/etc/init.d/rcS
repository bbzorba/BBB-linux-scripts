#!/bin/sh
# /etc/init.d/rcS - System initialisation

mount -t proc     none /proc
mount -t sysfs    none /sys
mount -t devtmpfs none /dev 2>/dev/null || {
    # devtmpfs not available - fall back to mdev
    mount -t tmpfs -o size=64k,mode=0755 none /dev
    echo /sbin/mdev > /proc/sys/kernel/hotplug
    /sbin/mdev -s
}

# Create essential device nodes if missing
[ -c /dev/console ] || mknod -m 600 /dev/console c 5 1
[ -c /dev/null ]    || mknod -m 666 /dev/null    c 1 3
[ -c /dev/tty ]     || mknod -m 666 /dev/tty     c 5 0

# Create runtime directories required by ifup and s-s-d
mkdir -p /var/run /var/lock /etc/network/if-pre-up.d /etc/network/if-up.d /etc/network/if-down.d /etc/network/if-post-down.d

# Mount the ext4 rootfs partition (read-only) so kernel modules are accessible.
# SD card layout: mmcblk0p1=BOOT(FAT) mmcblk0p2=swap mmcblk0p3=rootfs(ext4)
mkdir -p /mnt/rootfs
for part in /dev/mmcblk0p3 /dev/mmcblk0p2; do
    [ -b "$part" ] && mount -t ext4 -o ro "$part" /mnt/rootfs 2>/dev/null && break
done
if [ -d /mnt/rootfs/lib/modules ]; then
    mkdir -p /lib/modules
    mount --bind /mnt/rootfs/lib/modules /lib/modules
else
    echo "Warning: /lib/modules not found on rootfs partition - modprobe will not work"
fi

echo "Embedded Linux BBB - initramfs ready"


for i in /etc/init.d/S??* ;do

     # Ignore dangling symlinks (if any).
     [ ! -f "$i" ] && continue

     case "$i" in
	*.sh)
	    # Source shell script for speed.
	    (
		trap - INT QUIT TSTP
		set start
		. $i
	    )
	    ;;
	*)
	    # No sh extension, so fork subprocess.
	    $i start
	    ;;
    esac
done