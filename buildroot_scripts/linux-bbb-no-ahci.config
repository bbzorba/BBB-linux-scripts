# BeagleBone Black / AM335x does not have SATA/AHCI hardware.
# Disabling the entire ATA subsystem avoids a GCC 14 BUILD_BUG_ON in
# drivers/ata/libahci.c (triggered by any driver that selects SATA_HOST).
# CONFIG_ATA is not set

# Enable USB Ethernet gadget (g_ether / usb0) on the MUSB peripheral port.
# omap2plus_defconfig leaves USB_ETH and MUSB_GADGET unset; they are needed
# for the BBB's USB mini-B port to enumerate as a CDC Ethernet device.
CONFIG_USB_MUSB_GADGET=y
CONFIG_USB_ETH=m
CONFIG_USB_ETH_RNDIS=y
