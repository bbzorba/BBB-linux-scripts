# Toolchain: ARM GNU 14.2.rel1 locally installed
# Use CUSTOM + PREINSTALLED so Buildroot uses the local copy instead of downloading.
# Path = toolchain ROOT (dir containing bin/); Buildroot appends /bin/<prefix>-gcc automatically.
BR2_TOOLCHAIN_EXTERNAL=y
BR2_TOOLCHAIN_EXTERNAL_CUSTOM=y
BR2_TOOLCHAIN_EXTERNAL_PREINSTALLED=y
BR2_TOOLCHAIN_EXTERNAL_PATH="/home/bbzorba/Desktop/Embedded_Systems/BeagleBone_Black/ARM_Toolchain/arm-gnu-toolchain-14.2.rel1-x86_64-arm-none-linux-gnueabihf"
BR2_TOOLCHAIN_EXTERNAL_CUSTOM_PREFIX="arm-none-linux-gnueabihf"
BR2_TOOLCHAIN_EXTERNAL_GCC_14=y
BR2_TOOLCHAIN_EXTERNAL_HEADERS_5_10=y
BR2_TOOLCHAIN_EXTERNAL_CUSTOM_GLIBC=y
BR2_TOOLCHAIN_EXTERNAL_CXX=y
BR2_TOOLCHAIN_EXTERNAL_FORTRAN=y
BR2_TOOLCHAIN_EXTERNAL_OPENMP=y
# BR2_TOOLCHAIN_EXTERNAL_INET_RPC is not set

# System identity
BR2_TARGET_GENERIC_HOSTNAME="bbzorba-buildroot"
BR2_TARGET_GENERIC_ROOT_PASSWD="root"

# Kernel: built manually (5.10.168) - do not build here
# BR2_LINUX_KERNEL is not set

# Network
BR2_PACKAGE_DHCPCD=y
BR2_PACKAGE_OPENSSH=y
BR2_PACKAGE_CONNMAN=y
BR2_PACKAGE_WPA_SUPPLICANT=y
BR2_PACKAGE_WGET=y
BR2_PACKAGE_LIBCURL=y
BR2_PACKAGE_LIBCURL_CURL=y
BR2_PACKAGE_IPTABLES=y
BR2_SKIP_LEGACY=y

# Essential target utilities
BR2_PACKAGE_NANO=y
BR2_PACKAGE_HTOP=y
BR2_PACKAGE_LESS=y
BR2_PACKAGE_BASH=y
BR2_PACKAGE_E2FSPROGS=y
BR2_PACKAGE_UTIL_LINUX=y
BR2_PACKAGE_PROCPS_NG=y
BR2_PACKAGE_TZDATA=y

# Filesystem size: default 60M is too small for selected packages
BR2_TARGET_ROOTFS_EXT2_SIZE="256M"

# Note: apt (Debian APT) is not in Buildroot - packages are selected at build time.
# Add BR2_PACKAGE_OPKG=y for a runtime package manager on the target.
# Note: NetworkManager requires dynamic linking and heavy desktop deps;
# connman is the standard embedded replacement (Tizen, webOS, etc.).
